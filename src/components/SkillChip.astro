---
import type { Skill } from '../data/skills';

interface Props {
  skill: Skill;
}

const { skill } = Astro.props;
---

<span class="skill-chip">
  {
    skill.icon && (
      <img src={skill.icon} alt="" width="20" height="20" loading="lazy" class="skill-chip-icon" />
    )
  }
  <span class="skill-chip-name">{skill.name}</span>
</span>
